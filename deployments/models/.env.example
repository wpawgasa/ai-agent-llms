# =============================================================================
# vLLM Model Serving — Environment
# =============================================================================
# Copy this file to deployments/models/.env and fill in the values you need.
# Used by both docker-compose.yml (H100 80GB) and docker-compose.l4.yml (L4 24GB).
# The .env file is gitignored — never commit real tokens.
#
# Both compose files define a single generic `vllm` service. The model served
# and its flags are selected entirely here — pick ONE preset block below (or set
# VLLM_MODEL / VLLM_TOOL_CALL_PARSER yourself), then run:
#   docker compose up                           # H100
#   docker compose -f docker-compose.l4.yml up  # L4
#
# Prerequisite: the shared docker network must exist before `up`:
#   docker network create llm-benchmark-network
# (or bring up the deployments/local/ stack, which creates it).

# HuggingFace token — required for gated repos (accept Google's Gemma license on
# HF first). https://huggingface.co/settings/tokens
HF_TOKEN=

# Host port to expose the vLLM OpenAI-compatible API on. The container always
# listens on 8000 internally; this only changes the host-side port.
VLLM_PORT=8000

# Host directory for cached model weights (persists across container restarts so
# weights aren't re-downloaded). Defaults to ~/.cache/huggingface.
# HF_CACHE_DIR=/data/hf-cache

# =============================================================================
# Served model — set VLLM_MODEL + VLLM_TOOL_CALL_PARSER (required).
# Copy ONE preset block below, or fill these in manually.
# =============================================================================

VLLM_MODEL=
VLLM_TOOL_CALL_PARSER=

# Optional knobs (the compose file applies the defaults shown if left blank).
# IMPORTANT: keep comments on their OWN lines. An inline comment after an empty
# value (KEY=   # ...) is captured by Compose as the value itself, so the flag is
# wrongly treated as set. Only put a comment after a value that is non-empty.
# Container image — leave blank for the pinned default (vllm/vllm-openai:v0.20.0).
# Set for models needing a branch build, e.g. DiffusionGemma (see preset below).
VLLM_IMAGE=
# Set to 1 to enable vLLM's experimental v2 model runner (required by
# DiffusionGemma). Leave blank otherwise — the entrypoint unsets it when blank.
VLLM_USE_V2_MODEL_RUNNER=
# Set to any non-empty value to add --trust-remote-code. Leave blank to disable.
VLLM_TRUST_REMOTE_CODE=
VLLM_DTYPE=bfloat16
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192
# JSON, e.g. {"rope_scaling": null} for Gemma-4
VLLM_HF_OVERRIDES=
# e.g. fp8
VLLM_KV_CACHE_DTYPE=
# Set to any non-empty value (e.g. 1) to add --enforce-eager. Leave blank to disable.
VLLM_ENFORCE_EAGER=
# Extra raw vLLM flags appended verbatim, e.g. --tensor-parallel-size 2. Leave blank for none.
VLLM_EXTRA_ARGS=

# -----------------------------------------------------------------------------
# H100 80GB presets (docker-compose.yml) — Category A
# Gemma-4 requires VLLM_HF_OVERRIDES={"rope_scaling": null} and parser gemma4.
# -----------------------------------------------------------------------------
# Gemma-4 26B-A4B (BF16):
#   VLLM_MODEL=google/gemma-4-26B-A4B-it
#   VLLM_TOOL_CALL_PARSER=gemma4
#   VLLM_HF_OVERRIDES={"rope_scaling": null}
#
# Gemma-4 26B-A4B (FP8):
#   VLLM_MODEL=RedHatAI/gemma-4-26B-A4B-it-FP8-Dynamic
#   VLLM_TOOL_CALL_PARSER=gemma4
#   VLLM_HF_OVERRIDES={"rope_scaling": null}
#
# Gemma-4 31B (BF16 ~62GB — tight KV headroom; prefer FP8 if you hit OOM):
#   VLLM_MODEL=google/gemma-4-31B-it
#   VLLM_TOOL_CALL_PARSER=gemma4
#   VLLM_HF_OVERRIDES={"rope_scaling": null}
#
# Gemma-4 31B (FP8):
#   VLLM_MODEL=RedHatAI/gemma-4-31B-it-FP8-block
#   VLLM_TOOL_CALL_PARSER=gemma4
#   VLLM_HF_OVERRIDES={"rope_scaling": null}
#
# Qwen3.6-35B-A3B (BF16 ~70GB — very tight KV; prefer FP8 if you hit OOM):
#   VLLM_MODEL=Qwen/Qwen3.6-35B-A3B
#   VLLM_TOOL_CALL_PARSER=qwen3_coder
#
# Qwen3.6-35B-A3B (FP8):
#   VLLM_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
#   VLLM_TOOL_CALL_PARSER=qwen3_coder
#
# Qwen3.6-27B (BF16):
#   VLLM_MODEL=Qwen/Qwen3.6-27B
#   VLLM_TOOL_CALL_PARSER=qwen3_coder
#
# Qwen3.6-27B (FP8):
#   VLLM_MODEL=Qwen/Qwen3.6-27B-FP8
#   VLLM_TOOL_CALL_PARSER=qwen3_coder
#
# DiffusionGemma 26B-A4B (FP8) — needs the dgemma-branch image (vLLM PR #45163,
# unmerged as of 2026-06-11; no tagged release supports diffusion_gemma).
# Use :gemma instead of :gemma-cu129 if the host driver supports CUDA 13.0 (>= 580).
# --max-num-seqs 4 + diffusion_sampler overrides per the RedHatAI model card.
# REQUIRED: --attention-backend TRITON_ATTN. DiffusionGemma's 512 global_head_dim
# crashes FlashInfer's prefill autotune at warmup ("FlashInfer Internal Error:
# Invalid configuration"); vLLM auto-picks FlashInfer otherwise. On this branch
# image the VLLM_ATTENTION_BACKEND env var is gone — use the --attention-backend
# CLI flag (passed via VLLM_EXTRA_ARGS) instead.
# VLLM_KV_CACHE_DTYPE=fp8 works in combination with the TRITON_ATTN backend.
#   VLLM_MODEL=RedHatAI/diffusiongemma-26B-A4B-it-FP8-dynamic
#   VLLM_TOOL_CALL_PARSER=gemma4
#   VLLM_IMAGE=vllm/vllm-openai:gemma-cu129
#   VLLM_USE_V2_MODEL_RUNNER=1
#   VLLM_TRUST_REMOTE_CODE=1
#   VLLM_HF_OVERRIDES={"rope_scaling": null, "diffusion_sampler": "entropy_bound", "diffusion_entropy_bound": 0.1}
#   VLLM_EXTRA_ARGS=--max-num-batched-tokens 4096 --max-num-seqs 4 --attention-backend TRITON_ATTN

# -----------------------------------------------------------------------------
# L4 24GB presets (docker-compose.l4.yml) — Category B/C small Gemma-4 only
# -----------------------------------------------------------------------------
# Gemma-4 E4B:
#   VLLM_MODEL=google/gemma-4-E4B-it
#   VLLM_TOOL_CALL_PARSER=gemma4
#
# Gemma-4 E2B:
#   VLLM_MODEL=google/gemma-4-E2B-it
#   VLLM_TOOL_CALL_PARSER=gemma4
