{
    "$schema": "https://www.getbifrost.ai/schema",
    "client": {
        "drop_excess_requests": false,
        "allowed_origins": [
            "*"
        ],
        "enable_logging": true
    },
    "providers": {
        "openai": {
            "keys": [
                {
                    "name": "openai-primary",
                    "value": "env.OPENAI_API_KEY",
                    "models": [
                        "gpt-5.5-2026-04-23",
                        "gpt-5.4-mini-2026-03-17",
                        "gpt-5.4-nano-2026-03-17",
                        "gpt-5.4-2026-03-05",
                        "gpt-5.3-codex"
                    ],
                    "weight": 1.0
                }
            ]
        },
        "anthropic": {
            "keys": [
                {
                    "name": "anthropic-primary",
                    "value": "env.ANTHROPIC_API_KEY",
                    "models": [
                        "claude-opus-4-7",
                        "claude-sonnet-4-6",
                        "claude-haiku-4-5"
                    ],
                    "weight": 1.0
                }
            ],
            "network_config": {
                "default_request_timeout_in_seconds": 300
            }
        },
        "gemini": {
            "keys": [
                {
                    "name": "gemini-primary",
                    "value": "env.GEMINI_API_KEY",
                    "models": [
                        "gemini-3.1-pro-preview",
                        "gemini-3.1-flash-lite",
                        "gemini-3-flash-preview",
                        "gemini-2.5-pro",
                        "gemini-2.5-flash",
                        "gemini-2.5-flash-lite"
                    ],
                    "weight": 1.0
                }
            ]
        },
        "vllm-local": {
            "keys": [
                {
                    "name": "vllm-key",
                    "value": "dummy",
                    "models": [
                        "*"
                    ],
                    "weight": 1.0
                }
            ],
            "network_config": {
                "base_url": "http://vllm-model:8000",
                "default_request_timeout_in_seconds": 300
            },
            "custom_provider_config": {
                "base_provider_type": "openai",
                "allowed_requests": {
                    "chat_completion": true,
                    "chat_completion_stream": true
                }
            }
        }
    },
    "config_store": {
        "enabled": true,
        "type": "sqlite",
        "config": {
            "path": "/app/data/config.db"
        }
    },
    "logs_store": {
        "enabled": true,
        "type": "sqlite",
        "config": {
            "path": "/app/data/logs.db"
        }
    }
}