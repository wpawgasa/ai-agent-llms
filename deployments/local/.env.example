# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Copy this file to deployments/local/.env and fill in the values you need.
# At least one provider key is required for the BiFrost gateway to serve requests.
# The .env file is gitignored — never commit real keys.

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API Key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional providers (only needed if referenced in data/bifrost/config.json)
GROK_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# Gateway Runtime
# =============================================================================
# LOG_LEVEL=info
