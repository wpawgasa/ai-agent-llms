# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Copy this file to deployments/local/.env and fill in the values you need.
# At least one provider key is required for the BiFrost gateway to serve requests.
# The .env file is gitignored — never commit real keys.

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API Key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional providers (only needed if referenced in data/bifrost/config.json)
GROK_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# Gateway Runtime
# =============================================================================
# LOG_LEVEL=info

# Host UID/GID the gateway container runs as, so it can write to the
# bind-mounted ./data/bifrost (the bifrost entrypoint aborts if it cannot
# create /app/data/logs). Set these to your own user — run `id -u` and `id -g`.
# Compose reads them from this .env reliably (the shell's $UID is readonly and
# is not always exported). Defaults to 1000:1000 (the image's appuser) if unset.
UID=1000
GID=1000
VLLM_API_KEY=
